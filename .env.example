NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key

# Canonical site URL for auth redirects (Aspyre is primary; danieltucker.org is satellite).
NEXT_PUBLIC_SITE_PRIMARY_ORIGIN=https://www.aspyreconsulting.com.au

# Clerk multi-domain (production): In Clerk Dashboard → Domains, set aspyreconsulting.com.au
# as the primary domain and add danieltucker.org as a satellite. Add the clerk.* CNAME for
# each domain per Clerk’s DNS instructions. Until the primary domain is Aspyre, sign-in may
# still load scripts from clerk.danieltucker.org and redirect admin users to danieltucker.org.
# Blog + admin images (Vercel Blob). Required on Railway for posts to survive redeploys.
# Create store at https://vercel.com/dashboard/stores → copy token into Railway Variables too.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Must match your Vercel Blob store access mode. Use private if blog images use /api/blog/blob URLs.
BLOG_BLOB_ACCESS=private

# Optional: blob path for blog-posts.json (default: blog/blog-posts.json)
# BLOG_POSTS_BLOB_PATH=blog/blog-posts.json

# Contact form (Google SMTP / Google Workspace — use an App Password for SMTP_PASS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=daniel@nexusaspyre.com
SMTP_PASS=your_app_password_16_chars
CONTACT_TO_EMAIL=daniel@nexusaspyre.com

# Optional: show "Joining soon" team placeholders on /about/our-team (always on in local dev)
# NEXT_PUBLIC_SHOW_TEAM_PLACEHOLDERS=true
